  "keyFeatures": [
    "JWT-based authentication with 8-hour token expiry",
    "Cloudflare Turnstile CAPTCHA protection on login",
    "Role-based access control (RBAC) with granular permissions per module",
    "User management with profile photo upload via Cloudinary",
    "Profile management with admin flag support",
    "Module management for dynamic application sections",
    "Permissions matrix editor with per-profile CRUD-level access control",
    "Global route middleware enforcing authentication on all pages",
    "PostgreSQL database via Neon serverless with Drizzle ORM",
    "Responsive UI built with Vue 3 and Tailwind CSS"
  ],
  "publicApiSurface": [
